# Copy to .env and fill in your key.

# Gemini — used for (a) Hebrew->English translation at ingest/query time and
# (b) generating the grounded chat answer. The google-genai client reads this
# automatically. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Chat + preference-inference model. Any current Gemini text model works.
GEMINI_MODEL=gemini-2.5-flash

# Embedding model (assignment option B — local, no API key needed).
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# How many review chunks to retrieve per question.
TOP_K=6
